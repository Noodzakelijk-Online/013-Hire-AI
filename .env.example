# Core runtime
NODE_ENV=development
PORT=3000
DATABASE_URL=mysql://user:password@localhost:3306/hire_ai
JWT_SECRET=replace-with-a-long-random-secret
# The worker only runs for users who explicitly enabled scheduled background runs.
# Set to false to disable it instance-wide for maintenance.
AUTONOMOUS_SCHEDULER_ENABLED=true
JOB_SCRAPING_SCHEDULER_ENABLED=false
JOB_SCRAPING_INTERVAL_MINUTES=60
JOB_SCRAPING_MAX_JOBS_PER_RUN=100
# Optional comma-separated platform names. Leave blank to use every active configured source.
JOB_SCRAPING_ENABLED_PLATFORMS=

# Sensitive documents are rejected in production until this malware-scanner endpoint is configured.
FILE_MALWARE_SCAN_URL=

# Manus OAuth / Forge runtime
VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
OWNER_OPEN_ID=
OWNER_NAME=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=http://localhost:3000

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# AWS S3 document storage
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
